@inherits Alife.Framework.PluginUIBase
@implements IDisposable
@using Alife.Framework
@using AntDesign
@inject ConfigurationSystem ConfigurationSystem
@inject IMessageService MessageService

<div style="background: #fff; padding: 20px; border-radius: 8px;">
    <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 24px;">
        <Title Level="4" Style="margin: 0;">QQ 聊天配置 (OneBot v11)</Title>
        <div style="display: flex; align-items: center; gap: 8px;">
            @if (Plugin is QChatService qChat)
            {
                <Badge Status="@(qChat.IsConnected ? BadgeStatus.Success : BadgeStatus.Error)"
                       Text="@(qChat.IsConnected ? "已连接" : "未连接")"/>
                <Button Type="@ButtonType.Default"
                        Size="@ButtonSize.Small"
                        Icon="@IconType.Outline.Reload"
                        Loading="@isReconnecting"
                        OnClick="Reconnect">
                    重连
                </Button>
            }
        </div>
    </Flex>

    <Form TModel="QChatConfig" Model="@config" Layout="@FormLayout.Vertical">
        <FormItem Label="WebSocket URL">
            <Input @bind-Value="@config.Url" placeholder="例如: ws://127.0.0.1:3001"/>
        </FormItem>
        <FormItem Label="主人 QQ 号">
            <InputNumber @bind-Value="@config.OwnerId" Style="width: 100%;"/>
        </FormItem>

        @* ───── 运行时状态 ───── *@
        @if (service != null)
        {
            <Divider>运行时管理</Divider>

            <Tabs @bind-ActiveKey="@activeTabKey" Style="margin-bottom: 24px;">
                <TabPane Tab="系统概览" Key="overview">
                    <GridRow Gutter="16">
                        <GridCol Span="8">
                            <Card Size="CardSize.Small" Style="border-radius: 8px;">
                                <Text Type="TextElementType.Secondary" Style="display: block; margin-bottom: 4px;">
                                    总缓存消息
                                </Text>
                                <Text Strong
                                      Style="font-size: 18px;">@service.GroupStates.Values.Sum(i => i.MessageBuffer.Count) 条
                                </Text>
                            </Card>
                        </GridCol>
                        <GridCol Span="16">
                            <Card Size="CardSize.Small" Style="border-radius: 8px;">
                                <Text Type="TextElementType.Secondary" Style="display: block; margin-bottom: 4px;">
                                    活跃群组统计
                                </Text>
                                <Text Strong>@service.GroupStates.Count(kv => kv.Value.IsEnabled) 个激活中 /
                                    共 @service.GroupStates.Count 个记录
                                </Text>
                            </Card>
                        </GridCol>
                    </GridRow>
                </TabPane>

                @foreach (var kv in service.GroupStates.OrderBy(x => x.Key).Take(20))
                {
                    var groupId = kv.Key;
                    var info = kv.Value;
                    <TabPane Key="@groupId.ToString()">
                        <TabTemplate>
                            <span>
                                @(info.IsEnabled ? "🟢" : "⚪") @groupId
                                @if (info.MessageBuffer.Count > 0)
                                {
                                    <Badge Count="@info.MessageBuffer.Count" Style="margin-left: 4px;"/>
                                }
                            </span>
                        </TabTemplate>
                        <ChildContent>
                            <Card Size="CardSize.Small" Style="border-radius: 8px;">
                                <Flex Direction="FlexDirection.Vertical">
                                    <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center"
                                          Style="margin-bottom: 12px;">
                                        <div>
                                            <Space Align="SpaceAlign.Center">
                                                <SpaceItem>
                                                    <Text Strong Style="font-size: 16px;">群号: @groupId</Text>
                                                </SpaceItem>
                                                <SpaceItem>
                                                    @{
                                                        var remaining = config.FlushInterval - (DateTime.Now - info.LastFlushedTime).TotalSeconds;
                                                    }
                                                    <Tag Color="TagColor.Orange">
                                                        <Icon Type="@IconType.Outline.ClockCircle"/>
                                                        下次推送: @(remaining > 0 ? $"{remaining:F1}s" : "发送中...")
                                                    </Tag>
                                                </SpaceItem>
                                            </Space>
                                            <br/>
                                            <Text Type="TextElementType.Secondary" Style="font-size: 12px;">
                                                最后活动: @info.LastActivityTime.ToString("HH:mm:ss")</Text>
                                        </div>
                                        <Space>
                                            <SpaceItem>
                                                <Button Danger="@info.IsEnabled"
                                                        Type="@ButtonType.Primary"
                                                        Size="@ButtonSize.Small"
                                                        OnClick="@(() => service.QGroup(groupId, !info.IsEnabled))">
                                                    @(info.IsEnabled ? "停用" : "激活")
                                                </Button>
                                            </SpaceItem>
                                            <SpaceItem>
                                                <Button Type="@ButtonType.Default"
                                                        Size="@ButtonSize.Small"
                                                        Disabled="@(info.MessageBuffer.Count == 0)"
                                                        OnClick="@(() => service.FlushGroupBuffer(info))">
                                                    手动推送
                                                </Button>
                                            </SpaceItem>
                                        </Space>
                                    </Flex>

                                    <Divider Style="margin: 4px 0;"/>

                                    <div
                                        style="max-height: 200px; overflow-y: auto; background: #fafafa; padding: 8px; border-radius: 4px; font-family: monospace; font-size: 12px;">
                                        @if (info.MessageBuffer.Count > 0)
                                        {
                                            @foreach (var msg in info.MessageBuffer)
                                            {
                                                <div
                                                    style="margin-bottom: 4px; border-bottom: 1px solid #f0f0f0; padding-bottom: 2px;">
                                                    @msg
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div style="color: #bfbfbf; text-align: center; padding: 20px;">
                                                暂无缓存消息
                                            </div>
                                        }
                                    </div>
                                </Flex>
                            </Card>
                        </ChildContent>
                    </TabPane>
                }
            </Tabs>
        }

        @* ───── 行为配置 ───── *@
        <Divider>行为配置</Divider>

        <div style="margin-bottom: 16px;">
            <Text Type="TextElementType.Secondary" Style="display: block; margin-bottom: 8px;">快速预设</Text>
            <Space>
                <SpaceItem>
                    <Button OnClick="@ApplyDesktopPetPreset">桌宠模式</Button>
                </SpaceItem>
                <SpaceItem>
                    <Button OnClick="@ApplyQQBotPreset">QQ机器人模式</Button>
                </SpaceItem>
            </Space>
        </div>

        <GridRow Gutter="16">
            <GridCol Span="8">
                <FormItem Label="启用防抖">
                    <Switch @bind-Value="@config.DebounceEnabled"/>
                    <br/>
                    <Text Type="TextElementType.Secondary" Style="font-size: 12px;">收到消息时重置计时器</Text>
                </FormItem>
            </GridCol>
            <GridCol Span="8">
                <FormItem Label="缓冲间隔 (秒)">
                    <AntDesign.InputNumber @bind-Value="@config.FlushInterval" Min="0.5f" Step="0.5f"
                                           Style="width: 100%;"/>
                </FormItem>
            </GridCol>
            <GridCol Span="8">
                <FormItem Label="最大缓存条数">
                    <AntDesign.InputNumber @bind-Value="@config.MaxBufferMessages" Min="0" Style="width: 100%;"/>
                    <Text Type="TextElementType.Secondary" Style="font-size: 12px;">0 表示不限</Text>
                </FormItem>
            </GridCol>
        </GridRow>

        <FormItem Label="唤醒词">
            <Input @bind-Value="@config.WakingWords" Placeholder="逗号分隔，如: 小猫,喵喵"/>
            <Text Type="TextElementType.Secondary" Style="font-size: 12px;">消息中包含这些词时等效于 @@机器人</Text>
        </FormItem>
        <FormItem Label="主动发言概率">
            <AntDesign.InputNumber @bind-Value="@config.ProactiveChatProbability" Min="0f" Max="1f" Step="0.05f"
                                   Style="width: 100%;"/>
            <Text Type="TextElementType.Secondary" Style="font-size: 12px;">0 表示关闭，收到未@@消息时以此概率触发回复
            </Text>
        </FormItem>
        <FormItem Label="群聊额外提示">
            <TextArea @bind-Value="@config.GroupChatPrompt" Rows="2" Placeholder="发送缓存消息时附加的提示"/>
        </FormItem>

        <GridRow Gutter="16">
            <GridCol Span="8">
                <FormItem Label="回复后关闭群聊">
                    <Switch @bind-Value="@config.CloseGroupAfterFlush"/>
                    <br/>
                    <Text Type="TextElementType.Secondary" Style="font-size: 12px;">回复后自动进入非激活状态</Text>
                </FormItem>
            </GridCol>
            <GridCol Span="8">
                <FormItem Label="自动关闭群聊 (分钟)">
                    <AntDesign.InputNumber @bind-Value="@config.AutoCloseMinutes" Min="1f" Style="width: 100%;"/>
                </FormItem>
            </GridCol>
        </GridRow>

        <FormItem>
            <Button id="btn-save-plugin-config" Type="@ButtonType.Primary" OnClick="@Save">保存配置</Button>
        </FormItem>
    </Form>

    <Divider/>

    <div style="background: #f5f5f5; padding: 16px; border-radius: 4px;">
        <Text Strong>使用说明：</Text>
        <ul style="margin-top: 8px; padding-left: 20px; font-size: 13px; color: #666;">
            <li>确保已启动 OneBot v11 兼容的服务端（如 LLOneBot, NapCat, Go-CQHTTP）。</li>
            <li>在服务端配置中开启 正向 WebSocket 服务，端口需与此处填写的 URL 一致。</li>
            <li>保存配置后，如果未自动连接，可点击上方的"重连"按钮。</li>
        </ul>
    </div>
</div>

@code {
    string activeTabKey = "overview";
    QChatConfig config = new();
    QChatService? service;
    bool isReconnecting;
    System.Timers.Timer? refreshTimer;

    protected override void OnInitialized()
    {
        var result = ConfigurationSystem.GetConfiguration(PluginType);
        if (result is QChatConfig c)
            config = c with { };

        refreshTimer = new System.Timers.Timer(1000);
        refreshTimer.Elapsed += (_, _) => InvokeAsync(StateHasChanged);
        refreshTimer.Start();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        service = Plugin as QChatService;
    }

    void ApplyDesktopPetPreset()
    {
        config.DebounceEnabled = false;
        config.FlushInterval = 15f;
        config.MaxBufferMessages = 0;
        config.ProactiveChatProbability = 0;
        config.CloseGroupAfterFlush = false;
    }

    void ApplyQQBotPreset()
    {
        config.DebounceEnabled = true;
        config.FlushInterval = 2f;
        config.MaxBufferMessages = 5;
        config.ProactiveChatProbability = 0.1f;
        config.CloseGroupAfterFlush = true;
    }

    async Task Reconnect()
    {
        if (Plugin is QChatService qChat)
        {
            isReconnecting = true;
            try
            {
                await qChat.ReconnectAsync();
                MessageService.Success("重连指令已发送喵！");
            }
            catch (Exception ex)
            {
                MessageService.Error($"重连失败: {ex.Message}");
            }
            finally
            {
                isReconnecting = false;
                StateHasChanged();
            }
        }
    }

    void Save()
    {
        ConfigurationSystem.SetConfiguration(PluginType, config);
        MessageService.Success("QQ 聊天配置保存成功喵！");
    }

    public void Dispose()
    {
        refreshTimer?.Stop();
        refreshTimer?.Dispose();
    }
}
