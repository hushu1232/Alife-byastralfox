@using Alife.Components.Services
@inject CharacterSystem CharacterSystem
@inject ChatActivitySystem ChatActivitySystem
@inject ActivityNotifyService ActivityNotifyService
@implements IDisposable

<Flex Direction="FlexDirection.Vertical" Gap="@("12")" Style="width: 100%; align-items: center;">

    <!-- 系统入口组 -->
    <Tooltip Title="@("欢迎")" Placement="Placement.Right">
        <NavLink href="/welcome" Class="nav-item-icon" Match="NavLinkMatch.All" ActiveClass="active">
            <Icon Type="@IconType.Outline.Rocket" Style="font-size: 24px"/>
        </NavLink>
    </Tooltip>

    <Tooltip Title="@("系统管理")" Placement="Placement.Right">
        <NavLink id="nav-system" href="/system" Class="nav-item-icon" Match="NavLinkMatch.All" ActiveClass="active">
            <Icon Type="@IconType.Outline.Setting" Style="font-size: 24px"/>
        </NavLink>
    </Tooltip>

    <Divider Style="margin: 4px 0; background: rgba(255,255,255,0.1)"/>

    <!-- 角色列表 -->
    @foreach (Character character in CharacterSystem.GetAllCharacters())
    {
        ActivityActivationState? activationState = ActivityNotifyService.GetActivationState(character.Name);
        ActivityActivationPresentation? activityPresentation = ActivityNotifyService.GetActivationPresentation(activationState);
        <Tooltip Title="@(activityPresentation == null ? character.Name : $"{character.Name} - {activityPresentation.Label}")" Placement="@Placement.Right">
            <NavLink href="@($"agent/{character.Name}")" Class="nav-item-icon character-item" ActiveClass="active">
                <div style="position: relative; display: flex; align-items: center; justify-content: center;">
                    <Avatar Size="@AvatarSize.Large" Style="background: #1890ff; color: #fff; font-weight: bold;">
                        @(character.Name.FirstOrDefault())
                    </Avatar>

                    @if (activityPresentation != null)
                    {
                        <span class="status-dot @activityPresentation.CssClass"
                              aria-label="@activityPresentation.Label"
                              title="@activityPresentation.Label"
                              style="position: absolute; bottom: 0; right: 0;"></span>
                    }
                </div>
            </NavLink>
        </Tooltip>
    }
</Flex>

<style>
    .nav-item-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        color: rgba(255, 255, 255, 0.6);
        cursor: pointer;
        position: relative;
    }

    .nav-item-icon:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        transform: scale(1.1);
    }

    .status-initializing { background-color: #1890ff; }
    .status-active { background-color: #52c41a; }
    .status-failed { background-color: #ff4d4f; }
    .status-stopped { background-color: #8c8c8c; }

</style>

@code {
    protected override void OnInitialized()
    {
        CharacterSystem.OnChanged += Refresh;
        ActivityNotifyService.OnActivationStateChanged += RefreshActivationState;
    }

    void Refresh() => InvokeAsync(StateHasChanged);
    void RefreshActivationState(ActivityActivationStatus _) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        CharacterSystem.OnChanged -= Refresh;
        ActivityNotifyService.OnActivationStateChanged -= RefreshActivationState;
    }
}
