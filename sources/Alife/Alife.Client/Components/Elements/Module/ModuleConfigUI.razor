@using Newtonsoft.Json
@using System.Reflection
@using Alife.Components
@inject ConfigurationSystem ConfigurationSystem

<div class="module-config-shell">
    <Card Size="CardSize.Small" Class="module-config-card">
        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Wrap="FlexWrap.Wrap" Gap="@("12")">
            <div>
                <Title Level="4" Style="margin: 0;">@GetModuleDisplayName()</Title>
                <Text Type="TextElementType.Secondary">@GetModuleFullName()</Text>
            </div>
            <AstralFoxDevMark />
        </Flex>
    </Card>

    <div class="module-config-body">
        @if (customUIType != null && customUIParameters.Count > 0)
        {
            <DynamicComponent Type="customUIType" Parameters="customUIParameters"/>
        }
        else
        {
            @CreateDefaultUI()
        }
    </div>

    @if (ConfigurationSystem.CanConfiguration(ModuleType))
    {
        <Card Size="CardSize.Small" Class="module-config-card save-card">
            <ConfigSaveUI ModuleType="@ModuleType"
                          Configuration="@GetConfigFromText()"
                          CharacterName="@Character?.Name"
                          OnConfigurationChanged="@OnConfigChanged"/>
        </Card>
    }
</div>

@code {
    [Parameter] public Character Character { get; set; } = null!;
    [Parameter] public Type ModuleType { get; set; } = null!;

    string moduleConfiguration = "{}";
    Type? customUIType;
    Dictionary<string, object> customUIParameters = new();

    RenderFragment CreateDefaultUI() =>
        @<div class="default-config-editor">
            <Text Type="TextElementType.Secondary">此模块没有专用配置界面，可以直接编辑 JSON 配置。</Text>
            <TextArea Style="min-height: 260px; border-radius: 8px; font-family: Consolas, monospace;"
                      @bind-Value="moduleConfiguration"/>
        </div>;

    object? GetConfigFromText()
    {
        try
        {
            Type type = ConfigurationSystem.GetConfigurationType(ModuleType)!;
            return JsonConvert.DeserializeObject(moduleConfiguration, type);
        }
        catch
        {
            return null;
        }
    }

    void OnConfigChanged(object newConfig)
    {
        moduleConfiguration = JsonConvert.SerializeObject(newConfig, Formatting.Indented);
        StateHasChanged();
    }

    string GetModuleDisplayName()
    {
        ModuleAttribute? attr = ModuleType.GetCustomAttribute<ModuleAttribute>();
        return attr?.Name ?? ModuleType.Name;
    }

    string GetModuleFullName()
    {
        return ModuleType.FullName ?? ModuleType.Name;
    }

    protected override void OnParametersSet()
    {
        var attr = ModuleType.GetCustomAttribute<ModuleAttribute>();
        moduleConfiguration = ConfigurationSystem.GetConfigurationJson(ModuleType)?.ToString(Formatting.Indented) ?? "{}";

        object? config = null;
        if (ConfigurationSystem.CanConfiguration(ModuleType))
        {
            object? raw = ConfigurationSystem.GetConfiguration(ModuleType, Character?.StorageKey ?? "");
            if (raw != null)
            {
                string json = JsonConvert.SerializeObject(raw);
                config = JsonConvert.DeserializeObject(json, raw.GetType());
            }
        }

        if (attr?.EditorUI != null)
        {
            customUIType = attr.EditorUI;
            customUIParameters = new Dictionary<string, object?>
            {
                { "Character", Character },
                { "DefaultUI", CreateDefaultUI() },
            }!;
            if (config != null)
                customUIParameters["Configuration"] = config;
        }
        else
        {
            customUIType = null;
        }
    }
}

<style>
    .module-config-shell {
        display: flex;
        flex-direction: column;
        gap: 16px;
        background: #fafafa;
        border: 1px solid #f0f0f0;
        border-radius: 8px;
        padding: 16px;
    }

    .module-config-card {
        border-radius: 8px;
    }

    .module-config-body {
        min-width: 0;
    }

    .save-card {
        background: #fff;
    }

    .default-config-editor {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
</style>
