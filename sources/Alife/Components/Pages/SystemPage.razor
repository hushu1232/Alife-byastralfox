@page "/"
@inject CharacterSystem CharacterSystem
@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        if (!CharacterSystem.GetAllCharacters().Any())
        {
            Navigation.NavigateTo("/welcome", replace: true);
        }
        else
        {
            Navigation.NavigateTo("/system", replace: true);
        }
    }
}
